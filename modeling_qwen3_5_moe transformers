class Qwen3_5MoeVisionRotaryEmbedding(nn.Module):
    # 只负责生成旋转的“相位”基础（cos 和 sin），而不是执行最终的向量旋转，具体的 RoPE 旋转计算是在apply_rotary_pos_emb 函数里进行的。
    inv_freq: torch.Tensor  # 显式声明，解决静态检查工具对 buffer 的报错

    def __init__(self, dim: int, theta: float = 10000.0) -> None:
        super().__init__()
        self.dim = dim      # 嵌入的维度（head_dim）
        self.theta = theta  # 底数，决定波长（通常是 10000 或更大）
        
        # 计算逆频率 (Inverse Frequencies)：基于公式 1 / theta^(2i/d)
        # torch.arange(0, dim, 2) 生成 [0, 2, 4, ..., dim-2] 的序列
        inv_freq = 1.0 / (theta ** (torch.arange(0, dim, 2, dtype=torch.float) / dim))
        
        # 注册为 buffer，不属于参数（不更新梯度），但会随模型保存和移动设备
        # persistent=False 表示该 buffer 不会保存到 state_dict 中
        self.register_buffer("inv_freq", inv_freq, persistent=False)

    def forward(self, seqlen: int) -> torch.Tensor:
        # 生成序列索引 [0, 1, 2, ..., seqlen-1]
        seq = torch.arange(seqlen, device=self.inv_freq.device, dtype=self.inv_freq.dtype)
        
        # 计算外积 (Outer Product)：将位置索引与逆频率相乘，得到相位矩阵
        # 结果维度: (seq_len, dim/2)
        freqs = torch.outer(seq, self.inv_freq)
        return freqs


class Qwen3_5MoeTextRotaryEmbedding(nn.Module):
    inv_freq: torch.Tensor

    def __init__(self, config: Qwen3_5MoeTextConfig, device=None):
        super().__init__()
        # 初始化最大序列长度缓存和配置
        self.max_seq_len_cached = config.max_position_embeddings
        self.original_max_seq_len = config.max_position_embeddings
        self.config = config

        # 从配置中读取 RoPE 类型（如 default, linear, dynamic 等）
        self.rope_type = self.config.rope_parameters["rope_type"]
        
        # 默认使用标准的 RoPE 参数计算函数
        rope_init_fn: Callable = self.compute_default_rope_parameters
        # 如果不是默认类型，则从全局映射表中查找对应的初始化函数（用于外推或缩放）
        if self.rope_type != "default":
            rope_init_fn = ROPE_INIT_FUNCTIONS[self.rope_type]
        
        # 执行初始化函数，得到逆频率矩阵和缩放因子
        inv_freq, self.attention_scaling = rope_init_fn(self.config, device)

        # 注册 inv_freq，并保留一份原始备份用于后续动态更新对比
        self.register_buffer("inv_freq", inv_freq, persistent=False)
        self.register_buffer("original_inv_freq", inv_freq.clone(), persistent=False)
        
        # mrope_section 定义了在隐藏维度中，Temporal(时间)、Height(高度)、Width(宽度) 各自占据的比例
        # 默认 [11, 11, 10] 表示 32 维里分别占 11, 11, 10 维
        # [11, 11, 10]：这是默认值。如果配置里没写，就按这个比例拆分。
        self.mrope_section = config.rope_parameters.get("mrope_section", [11, 11, 10])

    @staticmethod
    def compute_default_rope_parameters(
        config: Qwen3_5MoeTextConfig | None = None,
        device: Optional["torch.device"] = None,
        seq_len: int | None = None,
    ) -> tuple["torch.Tensor", float]:
        # 从配置中提取旋转角度基数 (Base)
        base = config.rope_parameters["rope_theta"]
        # 部分旋转因子：决定是全维度旋转还是部分维度旋转
        partial_rotary_factor = config.rope_parameters.get("partial_rotary_factor", 1.0)
        # 计算每个 Head 的维度，如果配置里没有，则用总维度除以头数
        head_dim = getattr(config, "head_dim", None) or config.hidden_size // config.num_attention_heads
        # 实际参与旋转的维度
        dim = int(head_dim * partial_rotary_factor)

        attention_factor = 1.0  # 默认不进行注意力缩放

        # 标准 RoPE 逆频率公式计算
        inv_freq = 1.0 / (
            base ** (torch.arange(0, dim, 2, dtype=torch.int64).to(device=device, dtype=torch.float) / dim)
        )
        return inv_freq, attention_factor

    @torch.no_grad()
    @dynamic_rope_update  # 装饰器：根据实际输入长度动态更新 inv_freq（处理长文本外推）
    def forward(self, x, position_ids):
        # Qwen3.5Moe 使用 3D 位置 ID (针对 T, H, W)，所以将 position_ids 扩展到 3 个维度
        # 通常情况下，输入的 position_ids 形状是 [Batch_Size, Seq_Len]
        # 形状变化: (bs, seq) -> (3, bs, seq)
        if position_ids.ndim == 2:
            position_ids = position_ids[None, ...].expand(3, position_ids.shape[0], -1)
            
        # 扩展逆频率矩阵以便进行批矩阵乘法，形状变为 (3, bs, dim/2, 1)
        inv_freq_expanded = self.inv_freq[None, None, :, None].float().expand(3, position_ids.shape[1], -1, 1)
        # 扩展位置 ID，形状变为 (3, bs, 1, seq)
        position_ids_expanded = position_ids[:, :, None, :].float()

        device_type = x.device.type if isinstance(x.device.type, str) and x.device.type != "mps" else "cpu"
        # 禁用自动混合精度，强制在 float32 下计算以保证位置信息的精确性
        with maybe_autocast(device_type=device_type, enabled=False):
            # 核心计算：inv_freq 与 position_ids 做矩阵乘法得到每个位置的相位
            # inv_freq_expanded.shape = (3, bs, dim/2, 1)
            # position_ids_expanded.shape = (3, bs, 1, seq)
            # freqs.shape = (3, bs, seq, dim/2)
            freqs = (inv_freq_expanded.float() @ position_ids_expanded.float()).transpose(2, 3)
            
            # 调用交错 MRoPE 函数，将 T, H, W 的频率混合到一起
            freqs = self.apply_interleaved_mrope(freqs, self.mrope_section)
            
            # 拼接 freqs 得到完整的旋转矩阵 (cos/sin 查表用)，对应公式中的 [f, f]
            # emb.shape = (bs, seq, dim/2*2)
            emb = torch.cat((freqs, freqs), dim=-1)
            
            # 计算 cos 和 sin 值，并应用缩放因子
            # emb.cos()：计算每个角度的余弦值
            # emb.sin()：计算每个角度的正弦值
            # self.attention_scaling: 通常用于处理长文本外推，当序列长度（seq_len）变得非常大时，点积注意力（Dot-product Attention）的分数可能会变得非常大，导致 Softmax 饱和。
            # 通过给 cos 和 sin 乘以一个缩放因子（比如来自线性内插或 YaRN 等方案的系数），可以减小旋转的“步长”或调整注意力的分布，从而让模型在处理比训练时更长的文本时，依然能保持稳定的注意力。
            cos = emb.cos() * self.attention_scaling
            sin = emb.sin() * self.attention_scaling

        # 将结果转回输入数据的数据类型（如 bfloat16）
        return cos.to(dtype=x.dtype), sin.to(dtype=x.dtype)

    def apply_interleaved_mrope(self, freqs, mrope_section):
        """将 3D (T, H, W) 频率交错重组"""
        """Apply interleaved MRoPE to 3D rotary embeddings.
        Reorganizes frequency layout from chunked [TTT...HHH...WWW] to
        interleaved [THWTHWTHW...TT], preserving frequency continuity.
        args:
            x: (3, bs, seq_len, head_dim // 2)
            mrope_section: (3,)
        returns:
            x_t: (bs, seq_len, head_dim // 2)
        """
        # 预设结果为时间维度 (T) 的频率
        # freqs_t.shape = (bs, seq, dim/2)
        freqs_t = freqs[0]  
        
        # 遍历高度 (H) 和宽度 (W) 维度，进行交错插入
        # 如果你的元组换成 (10, 20)，那么：
        # 第一轮：dim=1, offset=10
        # 第二轮：dim=2, offset=20
        # 发现规律了吗？dim 始终是 1, 2, 3... 这样数下去的，而 offset 则是跟着你元组里的数字走。
        for dim, offset in enumerate((1, 2), start=1):  
            # 计算在该段内的总长度
            length = mrope_section[dim] * 3
            # 使用切片：从 offset 开始，步长为 3 (实现 THW 交错排列)
            idx = slice(offset, length, 3)
            # 将 H 或 W 对应的频率值填入指定位置
            freqs_t[..., idx] = freqs[dim, ..., idx]
            
        return freqs_t


class Qwen3_5MoeRMSNormGated(nn.Module):
    def __init__(self, hidden_size, eps=1e-6, **kwargs):
        super().__init__()
        # 初始化可学习的缩放参数 weight，形状为 (hidden_size,)，初始值全为 1
        self.weight = nn.Parameter(torch.ones(hidden_size))
        # 防止分母为 0 的极小值（平滑因子）
        self.variance_epsilon = eps

    def forward(self, hidden_states, gate=None):
        # 记录输入张量的原始数据类型（如 Float16 或 BFloat16）
        input_dtype = hidden_states.dtype
        # 为了保证数值计算的稳定性，将输入转为 Float32
        hidden_states = hidden_states.to(torch.float32)
        
        # 计算 RMS 归一化所需的分母：对最后一个维度求平方的平均值
        # 公式对应：RMS(x) = sqrt(1/n * sum(x^2))
        variance = hidden_states.pow(2).mean(-1, keepdim=True)
        
        # 执行归一化操作：x = x / sqrt(variance + eps)
        # torch.rsqrt 是平方根的倒数，效率更高
        hidden_states = hidden_states * torch.rsqrt(variance + self.variance_epsilon)
        
        # 将归一化后的数据转回原始类型，并应用可学习的缩放参数 self.weight
        hidden_states = self.weight * hidden_states.to(input_dtype)
        
        # 门控机制：将处理后的状态与经过 SiLU 激活函数的 gate 张量相乘
        # gate 通常源自模型中专家选择（MoE）或路由逻辑的输出
        hidden_states = hidden_states * F.silu(gate.to(torch.float32))

        # 最终输出转回原始数据类型
        # 混合精度: 这个实现非常贴心，它在内部自动将计算转为 float32，计算完成后再转回输入时的精度（如 float16），这能有效防止训练过程中的梯度爆炸或数值下溢。
        return hidden_states.to(input_dtype)


def apply_mask_to_padding_states(hidden_states, attention_mask):
    """
    针对填充标记调整隐藏状态，参考 https://github.com/state-spaces/mamba/issues/66
    """
    # 检查注意力掩码是否存在，且 batch_size 和 sequence_length 均大于 1
    # 这样可以避免在处理单个 token 或单条数据时进行不必要的计算
    if attention_mask is not None and attention_mask.shape[1] > 1 and attention_mask.shape[0] > 1:
        
        # 记录原始数据类型（如 float16 或 bfloat16），确保计算后精度一致
        dtype = hidden_states.dtype
        
        # 将 attention_mask 扩展到与 hidden_states 相同的维度（Batch, Seq, 1）
        # hidden_states.shape = [Batch, Seq_len, Hidden_dim]。
        # attention_mask.shape = [Batch, Seq_len]
        # 执行逐元素乘法，将 mask 为 0（填充位）对应的 hidden_states 置为 0
        hidden_states = (hidden_states * attention_mask[:, :, None]).to(dtype)

    # 返回处理后的隐藏状态
    return hidden_states

